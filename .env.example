# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/autopilotai

# --- Auth (JWT) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Gemini (Google AI Studio) ---
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# --- CORS ---
# Comma-separated list of allowed frontend origins. Include the Vercel
# production URL (and any preview URLs) alongside localhost for local dev.
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# --- Job boards (V2, Checkpoint 10) ---
# Both optional: if either provider's keys are left blank, that provider is
# silently skipped in GET /jobs/search (same as a provider being temporarily down).
# Adzuna: free signup at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us
# USAJobs: free signup at https://developer.usajobs.gov - User-Agent must be the
# email address you registered with, it's how USAJobs identifies your account.
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=you@example.com

