# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/autopilotai

# --- Auth (JWT) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Gemini (Google AI Studio) ---
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# --- CORS ---
# Comma-separated list of allowed frontend origins. Include the Vercel
# production URL (and any preview URLs) alongside localhost for local dev.
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

